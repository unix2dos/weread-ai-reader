{
  "manifest_version": 3,
  "name": "WeRead AI Reader",
  "version": "0.1.0",
  "description": "AI-powered reading companion for WeChat Read",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://weread.qq.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://weread.qq.com/web/reader/*"],
      "js": ["content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "popup.html"
  }
}
